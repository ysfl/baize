# 白泽公开发布仓部署模板
# 推荐使用 scripts/init-config.sh 生成 .env，脚本会生成随机密码和密钥。
# 本文件只描述可配置项，不应直接作为生产 .env 使用。

BAIZE_LANG=zh

POSTGRES_USER=baize
POSTGRES_PASSWORD=
POSTGRES_DB=baize
POSTGRES_PUBLIC_PORT=15432

REDIS_PASSWORD=
REDIS_DB=0
REDIS_PUBLIC_PORT=16379

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_PUBLIC_PORT=22501
SERVER_MODE=release
SERVER_TARGET_ARCH=amd64
SERVER_TARGET_PLATFORM=linux/amd64
BAIZE_DEPLOY_MODE=auto
BAIZE_STACK_MODE=full
BAIZE_VERSION=0.1.39
BAIZE_SERVER_VERSION=0.1.39
BAIZE_WEB_VERSION=0.1.38
BAIZE_SERVER_IMAGE=ghcr.io/ysfl/baize-server:0.1.39
BAIZE_WEB_IMAGE=ghcr.io/ysfl/baize-web:0.1.38

WEB_PUBLIC_PORT=8088
WEB_CONTAINER_PORT=8080
WEB_API_BASE_URL=/api/v1
WEB_CLIENT_MAX_BODY_SIZE=100m
BAIZE_SERVER_UPSTREAM=server:8080
# 可选。设置后 Web 入口只接受这些域名，IP 直连或未知 Host 会被拒绝。
# 多个域名用逗号分隔，例如 <你的控制台域名>,<你的备用控制台域名>。
BAIZE_WEB_DOMAIN=
BAIZE_WEB_ALLOWED_HOSTS=

DB_HOST=postgres
DB_PORT=5432
DB_USER=baize
DB_PASSWORD=
DB_NAME=baize
DB_SSLMODE=disable

REDIS_ADDR=redis:6379

JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
CREDENTIAL_MASTER_KEY=

# 主机画像刷新和命令历史明文查看使用的独立安全码。
# 新安装会生成 BAIZE_HOST_PROFILE_SECURITY_CODE；生产环境可替换为 HASH 并清空明文。
BAIZE_HOST_PROFILE_SECURITY_CODE_HASH=
BAIZE_HOST_PROFILE_SECURITY_CODE=

CORS_ENABLED=true
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

AGENT_ARTIFACT_DIR=/app/agent/dist
AGENT_INSTALL_SCRIPT_PATH=/app/agent/dist/install.sh
AGENT_INSTALL_POWERSHELL_PATH=/app/agent/dist/install.ps1
AGENT_PUBLIC_SERVER_URL=http://127.0.0.1:22501
AGENT_UPGRADE_AUTO_TOKEN_TTL_HOURS=24
BAIZE_LOGIN_NOTICE_OFFICIAL_SITE_URL=https://baize.run
BAIZE_LOGIN_NOTICE_DISCORD_URL=https://discord.gg/UMR7mnZFqh
BAIZE_LOGIN_NOTICE_SUPPORT_URL=mailto:support@baize.run
BAIZE_LOGIN_NOTICE_ABUSE_REPORT_URL=mailto:support@baize.run
BAIZE_LOGIN_NOTICE_DISABLE_SECRET_SHA256=
BAIZE_LOGIN_NOTICE_REPORT_ENDPOINT=https://baize.run/api/v1/security/login-notice/disable-events
BAIZE_LOGIN_NOTICE_REPORT_TOKEN=

GEOIP_CITY_MMDB_PATH=/app/runtime/geoip/dbip-city-lite.mmdb
GEOIP_ASN_MMDB_PATH=/app/runtime/geoip/dbip-asn-lite.mmdb
GEOIP_OFFLINE_ONLY=true

BAIZE_RUNTIME_LOG_FILE_ENABLED=true
BAIZE_RUNTIME_LOG_DIR=/app/data/logs/baize-server
BAIZE_RUNTIME_LOG_FILE_MAX_SIZE_MB=50
BAIZE_RUNTIME_LOG_FILE_MAX_FILES=7
BAIZE_RUNTIME_LOG_INDEX_ENABLED=true

BAIZE_RELEASE_MANIFEST_PATH=/app/releases/manifest.env
BAIZE_SERVER_BUILD_INFO_PATH=/app/server/dist/build-info.env
BAIZE_AGENT_BUILD_INFO_PATH=/app/agent/dist/build-info.env
BAIZE_LATEST_MANIFEST_URL=https://raw.githubusercontent.com/ysfl/baize/main/releases/latest.json
BAIZE_RELEASE_CHANGELOG_URL=https://raw.githubusercontent.com/ysfl/baize/main/releases/changelog.json
BAIZE_UPGRADE_MODE=manual
BAIZE_UPGRADE_COMMAND=
BAIZE_DOCKER_UPGRADE_COMMAND=
BAIZE_HOST_UPGRADE_COMMAND=
BAIZE_UPGRADE_RUNNER_ENABLED=false
BAIZE_UPGRADE_LOG_DIR=/app/data/upgrade
BAIZE_DB_AUTO_MIGRATE=true
BAIZE_BACKUP_DIR=
BAIZE_BACKUP_KEEP_DAYS=14
